meta:
targets='gml_Object_obj_enemy_ct_Create_0'
critical=true
patch:
write('
enemy_score = 3 // cc score
')


meta:
targets='gml_Object_obj_enemy_ct_Draw_0'
critical=true
patch:
// draw using maggot's draw event, since the one in the game
// doesn't animate to the music
write('
event_perform_object(obj_enemy_cc, ev_draw, 0)
exit
')

