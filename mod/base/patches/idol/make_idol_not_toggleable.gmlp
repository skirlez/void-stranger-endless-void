meta:
targets=gml_Object_obj_menu_Draw_0
critical=true
patch:
// this makes it so the game only draws the "on" option for the idol

find_line_with('draw_text_color(rtx, rty, scrScript(8), c1, c1, c1, c1, 1)')
write_before('
if (ds_grid_get(obj_inventory.ds_equipment, 0, 4) != 0 && yy == 3 && ds_grid == ds_menu_equipment) {
    draw_text_color(rtx + 16, rty, scrScript(8), c, c, c, c, 1);
}
else {
')
move(1)
write_last('}')
