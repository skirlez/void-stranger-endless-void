# Ignore all PNG images in subfolders except those starting with "ev_"
sprites/**/*.png
!sprites/spr_ev_*/**/*.png

# Ignore all WAV files in subfolders except those starting with "ev_"
sounds/**/*.wav
!sounds/snd_ev_*/**/*.wav

# Ignore all images in the tilesets folder
tilesets/**/*.png

# g3man related ignores
g3man/igor
g3man/out
g3man/frida-config.ini
g3man/base/*
!g3man/base/mod/
g3man/__pycache__
g3man/frida-timestamp.txt